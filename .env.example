# =============================================================================
# SRD Digital / Digistore Checkout Bridge — Environment Variables
# Copy to .env.local for local dev. Set the same vars in Vercel for production.
# NEVER expose anything except the NEXT_PUBLIC_* vars to the browser.
# =============================================================================

# --- Supabase ---------------------------------------------------------------
# Project URL + anon key are safe for the browser (used only by admin login UI).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"
# Service-role key — SERVER ONLY. Bypasses RLS. Never send to the browser.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"

# --- App config -------------------------------------------------------------
# Public base URL of THIS Next.js app (used to build webhook/return URLs).
APP_BASE_URL="https://your-app.vercel.app"
# Comma-separated list of Shopify storefront origins allowed to call /api/public/*
# e.g. https://your-store.myshopify.com,https://yourcustomdomain.com
STOREFRONT_ALLOWED_ORIGINS="https://your-store.myshopify.com"

# --- Digistore24 ------------------------------------------------------------
# API key from Digistore24 → Settings → API/Connections. SERVER ONLY.
DIGISTORE_API_KEY="YOUR-DIGISTORE-API-KEY"
# IPN passphrase (SHA passphrase) configured on the Digistore IPN connection. SERVER ONLY.
DIGISTORE_IPN_PASSPHRASE="YOUR-IPN-PASSPHRASE"
# Base currency for price calculation (per-rule currency can override).
DEFAULT_CURRENCY="EUR"

# --- Shopify Admin API ------------------------------------------------------
# Custom app Admin API access token (shpat_...). SERVER ONLY.
SHOPIFY_ADMIN_API_TOKEN="shpat_YOUR-TOKEN"
# Your store's myshopify domain.
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
# Admin API version to target.
SHOPIFY_API_VERSION="2025-01"
# Optional: Shopify webhook signing secret if you also subscribe to Shopify webhooks.
SHOPIFY_WEBHOOK_SECRET=""

# --- Security ---------------------------------------------------------------
# Random 32+ char secret used to sign internal checkout-session tokens.
APP_SESSION_SECRET="generate-a-long-random-string"
